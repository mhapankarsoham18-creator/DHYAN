# ============================================
# Dhyan Backend — Environment Template
# ============================================
# Copy this file to .env.development for local development
# NEVER commit actual secrets to git
# ============================================

# --- Database (Local PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://dhyan_user:dhyan_password@localhost:5432/dhyan

# --- Redis (Local or Upstash) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT ---
JWT_SECRET=generate_a_random_32_byte_string_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=30

# --- AES Encryption (Broker Token Storage) ---
AES_MASTER_KEY=generate_a_random_32_byte_hex_string_here

# --- Firebase ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS=firebase_adminsdk.json

# --- Broker APIs (Sandbox/Paper Mode) ---
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
SHOONYA_API_KEY=
SHOONYA_CLIENT_ID=

# --- Razorpay (Test Mode) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Monitoring ---
SENTRY_DSN=

# --- App Config ---
ENV=development
